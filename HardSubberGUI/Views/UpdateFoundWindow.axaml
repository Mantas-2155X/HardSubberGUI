<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HardSubberGUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:HardSubberGUI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="265" d:DesignHeight="105"
        x:Class="HardSubberGUI.Views.UpdateFoundWindow"
        Background="{CompiledBinding MainPanelColor}"
        Width="350" Height="225"
        MinWidth="350" MinHeight="225"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/hardsubber.ico"
        Title="HardSubberGUI"
        x:DataType="viewModels:UpdateFoundViewModel">
    
    <Design.DataContext>
        <vm:UpdateFoundViewModel/>
    </Design.DataContext>
    
    <DockPanel Margin="5">
        <!--Bottom Panel-->
        <Panel DockPanel.Dock="Bottom" Height="30" Background="{CompiledBinding MainPanelColor}">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="5">
                <Button Name="NoControl" Width="125" HorizontalContentAlignment="Center" Content="{CompiledBinding No}" Click="No_OnClick" ToolTip.Tip="{CompiledBinding NoTooltip}"/>
                <Button Name="YesControl" Width="125" HorizontalContentAlignment="Center" Content="{CompiledBinding Yes}" Click="Yes_OnClick" ToolTip.Tip="{CompiledBinding YesTooltip}"/>
            </StackPanel>
        </Panel>
        
        <Panel DockPanel.Dock="Top" Background="{CompiledBinding MainPanelColor}">
            <DockPanel>
                <!--Title-->
                <TextBlock DockPanel.Dock="Top" TextAlignment="Center" VerticalAlignment="Center" Text="{CompiledBinding Text}"/>
        
                <!--Changes-->
                <ScrollViewer DockPanel.Dock="Top" Margin="0, 5, 0, 5" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="{CompiledBinding SecondaryPanelColor}">
                    <TextBlock TextAlignment="Left" VerticalAlignment="Top" Name="ChangesControl"/>
                </ScrollViewer>
            </DockPanel>
        </Panel>
    </DockPanel>
</Window>
